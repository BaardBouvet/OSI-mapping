{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BaardBouvet/OSI-mapping/spec/mapping-schema.json",
  "title": "Integration Mapping Schema v2",
  "description": "Source-to-target field mapping with conflict resolution. v2 schema — see docs/reference/schema-reference.md.",
  "type": "object",
  "required": ["version", "sources", "targets", "mappings"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "2.0",
      "description": "Schema version. Must be the string \"2.0\"."
    },
    "description": {
      "type": "string",
      "description": "Human-readable summary of what this mapping file does."
    },
    "sources": {
      "type": "object",
      "description": "Source dataset metadata, keyed by source name.",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/Identifier" },
      "additionalProperties": { "$ref": "#/$defs/Source" }
    },
    "targets": {
      "type": "object",
      "description": "Target entity definitions, keyed by target name.",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/Identifier" },
      "additionalProperties": { "$ref": "#/$defs/Target" }
    },
    "mappings": {
      "type": "array",
      "description": "Source-to-target field mappings.",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Mapping" }
    },
    "tests": {
      "type": "array",
      "description": "Inline test cases.",
      "items": { "$ref": "#/$defs/Test" }
    }
  },

  "$defs": {

    "Identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Lowercase identifier: starts with a letter, followed by letters, digits, or underscores."
    },

    "Source": {
      "type": "object",
      "description": "Source dataset metadata.",
      "required": ["primary_key"],
      "additionalProperties": false,
      "properties": {
        "primary_key": {
          "type": "string",
          "description": "Primary-key column name."
        }
      }
    },

    "Target": {
      "type": "object",
      "description": "Target entity definition.",
      "required": ["identity", "fields"],
      "additionalProperties": false,
      "properties": {
        "identity": {
          "type": "array",
          "description": "OR-list of identity groups. Each group is either a single field name (string) or an AND-tuple (list of field names).",
          "minItems": 1,
          "items": { "$ref": "#/$defs/IdentityGroup" }
        },
        "fields": {
          "type": "object",
          "description": "Target field definitions, keyed by field name.",
          "minProperties": 1,
          "propertyNames": { "$ref": "#/$defs/Identifier" },
          "additionalProperties": { "$ref": "#/$defs/Field" }
        }
      }
    },

    "IdentityGroup": {
      "oneOf": [
        {
          "type": "string",
          "description": "Single-field identity group.",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        {
          "type": "array",
          "description": "AND-tuple identity group: rows match only when all fields agree.",
          "minItems": 2,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      ]
    },

    "Field": {
      "type": "object",
      "description": "Target field definition.",
      "required": ["strategy"],
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["coalesce", "last_modified"],
          "description": "Resolution strategy for this field."
        }
      }
    },

    "Mapping": {
      "type": "object",
      "description": "One source-to-target mapping.",
      "required": ["name", "source", "target", "fields"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/Identifier",
          "description": "Unique mapping name."
        },
        "source": {
          "$ref": "#/$defs/Identifier",
          "description": "Source dataset name (must match a key in sources)."
        },
        "target": {
          "$ref": "#/$defs/Identifier",
          "description": "Target entity name (must match a key in targets)."
        },
        "last_modified": {
          "type": "string",
          "description": "Source column carrying the row's last-modified timestamp. Required for mappings contributing to last_modified-strategy fields."
        },
        "parent": {
          "$ref": "#/$defs/Identifier",
          "description": "Name of a parent mapping — makes this a child mapping that expands an array column from the parent source."
        },
        "array": {
          "type": "string",
          "description": "Source column (or dotted path) holding the array to expand. Required when parent: is set."
        },
        "parent_fields": {
          "type": "object",
          "description": "Aliases that lift parent-row columns into the child's scope. Keys are alias names; values are parent source columns.",
          "propertyNames": { "$ref": "#/$defs/Identifier" },
          "additionalProperties": { "type": "string" }
        },
        "fields": {
          "type": "array",
          "description": "Field mappings: source column → target field.",
          "minItems": 1,
          "items": { "$ref": "#/$defs/FieldMap" }
        }
      }
    },

    "FieldMap": {
      "type": "object",
      "description": "One source column to one target field.",
      "required": ["source", "target"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Source column name."
        },
        "target": {
          "$ref": "#/$defs/Identifier",
          "description": "Target field name."
        },
        "priority": {
          "type": "integer",
          "description": "Priority for coalesce resolution. Lower wins. Omit to use declaration order."
        },
        "references": {
          "$ref": "#/$defs/Identifier",
          "description": "(Slice 4) Name of another target whose canonical IRI resolves this field on reverse — declares a foreign-key relationship."
        }
      }
    },

    "Test": {
      "type": "object",
      "description": "Inline test case.",
      "required": ["description", "input", "expected"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable description of what this test asserts."
        },
        "input": {
          "type": "object",
          "description": "Current state of each source. Keys are source names; values are arrays of rows.",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "object" }
          }
        },
        "expected": {
          "type": "object",
          "description": "Expected delta output. Keys are mapping names (or source names for single-mapping files).",
          "additionalProperties": { "$ref": "#/$defs/Expected" }
        }
      }
    },

    "Expected": {
      "type": "object",
      "description": "Expected deltas for one mapping. Empty object asserts no deltas.",
      "additionalProperties": false,
      "properties": {
        "updates": {
          "type": "array",
          "items": { "type": "object" }
        },
        "inserts": {
          "type": "array",
          "items": { "type": "object" }
        },
        "deletes": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    }
  }
}
